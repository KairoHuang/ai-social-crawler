# Firecrawl API Key - 从 https://firecrawl.dev 获取
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key - 用于 AI 分析和内容提取
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Twitter / X (twscrape — 免费，使用 Twitter 内部 API) ──────────────────
# 方式1 (推荐): Cookie 字符串
# 浏览器登录 x.com → F12 → Network → 任意请求 → Request Headers → 复制 Cookie 整行
# 关键字段：auth_token 和 ct0
TWITTER_COOKIES=

# 方式2: 账号密码（twscrape 自动完成登录）
TWITTER_USERNAME=
TWITTER_PASSWORD=
# 如果账号开启了两步验证还需要邮箱
TWITTER_EMAIL=
TWITTER_EMAIL_PASSWORD=

# ─── Instagram (instagrapi — 免费，使用 Instagram 私有 API) ─────────────────
# 必填：账号密码
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
# session 会自动缓存到 output/sessions/ 目录，下次无需重新登录

# ─── Reddit 登录 (可选，公开内容无需登录) ────────────────────────────────────
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_COOKIES=
